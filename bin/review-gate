#!/usr/bin/env bash
# review-gate launcher. Resolves the compiled spine relative to THIS script, so it works on PATH from
# any working directory — Claude Code adds a plugin's bin/ to the Bash PATH, so once the plugin is
# installed the skill can call `review-gate <verb>` with no path to the plugin. The spine has zero
# runtime deps, so plain `node` on the committed dist/ build runs it (no install-time build needed).
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
exec node "$here/../dist/cli.js" "$@"
